# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AWS Bedrock (for dynamic hypothesis evaluation in Critic interface)
# Get these from AWS IAM Console
NEXT_PUBLIC_AWS_ACCESS_KEY_ID=your-aws-access-key-id
NEXT_PUBLIC_AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
NEXT_PUBLIC_AWS_REGION=us-east-1

# Application Settings
NEXT_PUBLIC_APP_NAME="Oracle vs. Critic Experiment"
NEXT_PUBLIC_TARGET_N_PER_GROUP=30
NEXT_PUBLIC_TOTAL_TARGET_N=120

# Feature Flags
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false
NEXT_PUBLIC_SKIP_POST_TEST_DELAY=false

# Admin Dashboard (optional)
ADMIN_PASSWORD_HASH=your-hashed-password
